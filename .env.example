NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

STRIPE_SECRET_KEY=
# Local dev: http://localhost:3000 — production: https://dimadidenko.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hero showreel: `public/video/*.mp4` is gitignored — on Vercel set a public HTTPS URL or the page only shows the poster.
# NEXT_PUBLIC_SHOWREEL_URL=https://example.com/showreel.mp4

# Optional: “My music” podcast — by default the app loads /audio/podcast-{locale}.wav from public/audio/
# (e.g. public/audio/podcast-ru.wav). Override per locale (.mp3/.m4a URL on CDN is fine):
# NEXT_PUBLIC_PODCAST_AUDIO_EN=https://example.com/podcast-en.mp3
# NEXT_PUBLIC_PODCAST_AUDIO_RU=
# NEXT_PUBLIC_PODCAST_AUDIO_JA=
# NEXT_PUBLIC_PODCAST_AUDIO_DE=
# NEXT_PUBLIC_PODCAST_AUDIO_ZH=
# NEXT_PUBLIC_PODCAST_AUDIO_ES=
# NEXT_PUBLIC_PODCAST_AUDIO_FR=
# NEXT_PUBLIC_PODCAST_AUDIO_FALLBACK=https://example.com/podcast-en.wav
