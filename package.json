{
  "name": "music-store-by-dima-d",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true});}catch(_){}});\"",
    "dev": "next dev --turbo",
    "dev:fresh": "npm run clean && next dev --turbo",
    "dev:webpack": "next dev",
    "build": "next build",
    "start": "next start",
    "start:fresh": "npm run clean && npm run build && next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3"
  }
}
